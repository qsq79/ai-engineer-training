# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# 默认模型选择
# 可选值: gpt-4o-mini, gpt-4o, gpt-4-turbo, gpt-4, gpt-3.5-turbo
DEFAULT_MODEL=gpt-4o-mini

# Agent 配置
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=false

# 智能模型路由配置
ENABLE_MODEL_ROUTING=true
MODEL_ROUTING_DEBUG=false

# 模型路由规则说明:
# - 简单查询 (如 "get user info") 使用 gpt-4o-mini (快速、低成本)
# - 中等复杂度 使用 gpt-4o (平衡性能和成本)
# - 复杂任务 (如 "analyze", "debug") 使用 gpt-4-turbo (高性能)
# - 长对话或大量工具调用 使用 gpt-4 (最强能力)
# - 安全/认证相关任务 自动使用更高级别模型

# 自定义模型配置（可选）
# 格式: name:model_id:temperature:max_tokens;name2:model_id2:temperature2:max_tokens2
# 示例: CUSTOM_MODELS=deepseek:deepseek-chat:0.0:4096;claude:claude-3-sonnet:0.0:4096
# CUSTOM_MODELS=

# Ops Assistant API 配置
# 用户管理微服务的地址
OPS_API_BASE_URL=http://localhost:8000
OPS_API_TIMEOUT=30

# 工具调用错误处理日志配置
# TOOL_LOG_LEVEL=DEBUG   # 可选: DEBUG, INFO, WARNING, ERROR
# TOOL_LOG_FILE=logs/tool_errors.log  # 可选: 日志文件路径

# 可选：使用其他兼容 OpenAI 的 API
# OPENAI_API_BASE=https://api.deepseek.com/v1
# OPENAI_API_KEY=your_deepseek_api_key_here
