# 企业级安全智能助手 - 环境变量配置示例
# 复制此文件为.env并填入实际的配置值

# 应用基础配置
ESA_APP_NAME=Enterprise Security Assistant
ESA_APP_VERSION=1.0.0
ESA_DEBUG=false
ESA_HOST=0.0.0.0
ESA_PORT=8000

# 日志配置
ESA_LOG_LEVEL=INFO
ESA_LOG_FILE=logs/app.log
ESA_LOG_ROTATION=10 MB
ESA_LOG_RETENTION=30 days

# OpenAI配置
ESA_OPENAI_API_KEY=sk-WKrVcC2UkS1S6wRq6a59C794B87b49798e1dF89b51E78044
ESA_OPENAI_API_BASE=https://api.openai.com/v1
ESA_OPENAI_MODEL=gpt-4o
ESA_OPENAI_TEMPERATURE=0.7
ESA_OPENAI_MAX_TOKENS=2000

# 数据库配置
ESA_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/esa_db
ESA_DATABASE_POOL_SIZE=10
ESA_DATABASE_MAX_OVERFLOW=20

# Redis配置
ESA_REDIS_URL=redis://localhost:6379/0
ESA_REDIS_POOL_SIZE=10

# 向量数据库配置
ESA_VECTOR_DB_TYPE=chroma
ESA_CHROMA_PERSIST_DIRECTORY=./data/chroma

# JWT配置
ESA_JWT_SECRET_KEY=your-secret-key-here-change-in-production
ESA_JWT_ALGORITHM=HS256
ESA_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
ESA_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 限流配置
ESA_RATE_LIMIT_ENABLED=true
ESA_RATE_LIMIT_DEFAULT_QPS=100
ESA_RATE_LIMIT_TENANT_QPS=1000
ESA_RATE_LIMIT_USER_QPS=100
ESA_RATE_LIMIT_TOKEN_PER_DAY=1000000
ESA_RATE_LIMIT_CONCURRENT_REQUESTS=10

# 熔断配置
ESA_CIRCUIT_BREAKER_ENABLED=true
ESA_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
ESA_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# 监控配置
ESA_PROMETHEUS_ENABLED=true
ESA_TRACING_ENABLED=true

# CORS配置
ESA_CORS_ORIGINS=["http://localhost:3001", "http://localhost:8001"]
ESA_CORS_ALLOW_CREDENTIALS=true
ESA_CORS_ALLOW_METHODS=["*"]
ESA_CORS_ALLOW_HEADERS=["*"]
